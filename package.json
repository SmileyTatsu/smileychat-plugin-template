{
    "name": "smileychat-plugin-template",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "bun build ./src/index.ts --outdir ./dist --external preact && bun ./scripts/copy-static.ts",
